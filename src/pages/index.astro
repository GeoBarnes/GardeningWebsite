---
import BaseLayout from '../layouts/BaseLayout.astro';
import Testimonials from '../components/Testimonials.astro';
---

<BaseLayout title="Home">
  <section
    class="relative flex items-center justify-center min-h-[70vh] bg-forest text-white text-center px-6"
  >
    <div class="max-w-2xl">
      <h1 class="font-display text-4xl sm:text-5xl mb-4">
        Placeholder hero headline about beautiful gardens
      </h1>
      <p class="text-lg text-white/80 mb-8">
        One or two sentences here about the service on offer, in a warm and confident voice.
      </p>
      <a
        href="/contact/"
        class="inline-block bg-white text-forest px-6 py-3 rounded-full font-medium hover:bg-earth-light transition-colors"
      >
        Get in touch
      </a>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-6 py-16 grid sm:grid-cols-3 gap-8 text-center">
    <div>
      <h2 class="font-display text-xl mb-2">Placeholder service one</h2>
      <p class="text-forest/80 text-sm">Short description of what's on offer.</p>
    </div>
    <div>
      <h2 class="font-display text-xl mb-2">Placeholder service two</h2>
      <p class="text-forest/80 text-sm">Short description of what's on offer.</p>
    </div>
    <div>
      <h2 class="font-display text-xl mb-2">Placeholder service three</h2>
      <p class="text-forest/80 text-sm">Short description of what's on offer.</p>
    </div>
  </section>

  <!-- Renders nothing until the testimonials collection has entries. -->
  <Testimonials />

  <section class="bg-earth-light/20 py-16 text-center px-6">
    <h2 class="font-display text-2xl mb-4">See the work</h2>
    <p class="text-forest/80 mb-6">A preview of recent projects — full portfolio linked below.</p>
    <a href="/portfolio/" class="underline hover:text-forest-light">View the portfolio &rarr;</a>
  </section>
</BaseLayout>
