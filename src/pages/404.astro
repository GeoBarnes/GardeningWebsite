---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found">
  <section class="max-w-2xl mx-auto px-6 py-24 text-center">
    <h1 class="font-display text-3xl mb-4">Page not found</h1>
    <p class="text-forest/70 mb-8">The page you're looking for doesn't exist.</p>
    <a href="/" class="underline hover:text-forest-light">Back to home &rarr;</a>
  </section>
</BaseLayout>
