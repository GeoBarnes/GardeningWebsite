---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={project.data.title} description={project.data.summary}>
  <article class="max-w-3xl mx-auto px-6 py-16">
    <a href="/portfolio" class="text-sm underline hover:text-forest-light"
      >&larr; Back to portfolio</a
    >
    <h1 class="font-display text-3xl mt-4 mb-2">{project.data.title}</h1>
    <p class="text-forest/80 mb-8">{project.data.summary}</p>

    {
      project.data.beforeAfter && (
        <div class="grid grid-cols-2 gap-2 mb-8">
          <div>
            <img
              src={project.data.beforeAfter.before}
              alt={`${project.data.title} — before`}
              width="800"
              height="600"
              class="w-full aspect-[4/3] object-cover rounded-lg"
            />
            <p class="text-xs text-center mt-1 text-forest/80">Before</p>
          </div>
          <div>
            <img
              src={project.data.beforeAfter.after}
              alt={`${project.data.title} — after`}
              width="800"
              height="600"
              class="w-full aspect-[4/3] object-cover rounded-lg"
            />
            <p class="text-xs text-center mt-1 text-forest/80">After</p>
          </div>
        </div>
      )
    }

    <div class="grid sm:grid-cols-2 gap-4 mb-8">
      {
        project.data.images.map((src) => (
          <img
            src={src}
            alt={project.data.title}
            width="1200"
            height="800"
            loading="lazy"
            class="w-full aspect-[3/2] object-cover rounded-lg"
          />
        ))
      }
    </div>

    <div class="text-forest/80 leading-relaxed [&>p]:mb-4">
      <Content />
    </div>
  </article>
</BaseLayout>
