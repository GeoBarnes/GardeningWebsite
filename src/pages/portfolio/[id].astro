---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BeforeAfterSlider from '../../components/BeforeAfterSlider.astro';
import ProjectGallery from '../../components/ProjectGallery.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={project.data.title} description={project.data.summary}>
  <article class="max-w-3xl mx-auto px-6 py-16">
    <a href="/portfolio/" class="text-sm underline hover:text-forest-light"
      >&larr; Back to portfolio</a
    >
    <h1 class="font-display text-3xl mt-4 mb-2">{project.data.title}</h1>
    <p class="text-forest/80 mb-8">{project.data.summary}</p>

    {
      project.data.beforeAfter && (
        <BeforeAfterSlider
          before={project.data.beforeAfter.before}
          after={project.data.beforeAfter.after}
          title={project.data.title}
        />
      )
    }

    <ProjectGallery images={project.data.images} title={project.data.title} />

    <div class="text-forest/80 leading-relaxed [&>p]:mb-4">
      <Content />
    </div>
  </article>
</BaseLayout>
