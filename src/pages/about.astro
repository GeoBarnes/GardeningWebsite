---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About">
  <section class="max-w-3xl mx-auto px-6 py-16">
    <h1 class="font-display text-3xl mb-6">About</h1>

    <img
      src="https://placehold.co/800x600/8a7a63/ffffff?text=Profile+Photo"
      alt="Placeholder profile photo"
      width="800"
      height="600"
      class="w-full max-w-xs rounded-lg mb-8 float-none sm:float-right sm:ml-8 sm:mb-4"
    />

    <p class="mb-4 text-forest/80 leading-relaxed">
      Placeholder introduction paragraph — replace with a first-person profile written in her own
      voice. Cover how she got into gardening, her style or specialities, and what clients can
      expect from working with her.
    </p>
    <p class="mb-4 text-forest/80 leading-relaxed">
      Placeholder second paragraph — mention service area, experience, and anything that builds
      trust (qualifications, years of practice, favourite kinds of projects).
    </p>

    <a
      href="/contact"
      class="inline-block mt-4 bg-forest text-white px-6 py-3 rounded-full font-medium hover:bg-forest-light transition-colors"
    >
      Get in touch
    </a>
  </section>
</BaseLayout>
