---
import BaseLayout from '../layouts/BaseLayout.astro';
import LocalBusinessSchema from '../components/LocalBusinessSchema.astro';
import { BUSINESS } from '../config';

// Formspree endpoint. Safe to commit: it is a public identifier that ships in
// the page HTML by definition, so an env var would hide nothing.
const FORMSPREE_ENDPOINT = 'https://formspree.io/f/xojgnvrd';

// `_next` must be absolute, so derive it from the configured `site` rather than
// hardcoding the host in two places.
const thanksUrl = new URL('/contact/thanks/', Astro.site).href;
---

<BaseLayout title="Contact">
  <LocalBusinessSchema slot="head" />
  <section class="max-w-2xl mx-auto px-6 py-16">
    <h1 class="font-display text-3xl mb-2">Contact</h1>
    <p class="text-forest/80 mb-8">
      Get in touch about a project — or call/email directly if that's easier.
    </p>

    <!--
      Progressive enhancement. The markup is a real HTML POST to Formspree, so
      it works with no JavaScript — that path just lands on Formspree's own
      confirmation page. The script at the end of this file intercepts the
      submit, posts via `fetch`, and sends the visitor to our own
      /contact/thanks/ page instead. It's a few hundred hand-rolled bytes, not
      Formspree's SDK, and if the request fails for any reason it falls straight
      back to the plain POST — so the form can't be broken by the script.

      This matters because on Formspree's free plan the `_next` redirect below is
      ignored and every submission lands on their branded page; doing the
      redirect ourselves is what actually keeps people on her site.
    -->
    <form id="contact-form" class="space-y-4" method="POST" action={FORMSPREE_ENDPOINT}>
      <!-- Without this, every enquiry arrives titled "New submission". -->
      <input type="hidden" name="_subject" value="New enquiry from the website" />
      <!-- Return to our own thank-you page instead of Formspree's branded one. -->
      <input type="hidden" name="_next" value={thanksUrl} />
      <div>
        <label for="name" class="block text-sm font-medium mb-1">Name</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          class="w-full border border-earth-light/60 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-forest-light"
        />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium mb-1">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="w-full border border-earth-light/60 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-forest-light"
        />
      </div>
      <div>
        <label for="message" class="block text-sm font-medium mb-1">Message</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="w-full border border-earth-light/60 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-forest-light"
        ></textarea>
      </div>

      <!--
        Honeypot: off-screen for real users, bots fill it in. The name `_gotcha`
        is Formspree's own convention — they discard any submission where it is
        non-empty, so the filtering happens server-side rather than this field
        just sitting here inert. `tabindex="-1"` keeps it out of the tab order,
        which is also what makes the `aria-hidden` wrapper legitimate.
      -->
      <div class="absolute -left-[9999px]" aria-hidden="true">
        <label for="company">Company</label>
        <input type="text" id="company" name="_gotcha" tabindex="-1" autocomplete="off" />
      </div>

      <button
        type="submit"
        class="bg-forest text-white px-6 py-3 rounded-full font-medium hover:bg-forest-light transition-colors"
      >
        Send message
      </button>
    </form>

    <div class="mt-10 pt-8 border-t border-earth-light/40 text-forest/80 text-sm">
      <p>Prefer to call or email directly?</p>
      <p class="mt-1">
        Phone: <a href={`tel:${BUSINESS.telephone}`} class="underline"
          >{BUSINESS.telephoneDisplay}</a
        >
      </p>
      <p>Email: <a href={`mailto:${BUSINESS.email}`} class="underline">{BUSINESS.email}</a></p>
    </div>
  </section>
</BaseLayout>

<script>
  // Submit the contact form via fetch and handle the redirect ourselves, so the
  // visitor lands on our thank-you page rather than Formspree's branded one (a
  // plain POST hits that on the free plan, which ignores `_next`). Delegated to
  // `document`, which persists across Astro's view-transition body swaps, so it
  // keeps working without any per-navigation re-init.
  document.addEventListener('submit', async (event) => {
    const form = event.target;
    if (!(form instanceof HTMLFormElement) || form.id !== 'contact-form') return;
    event.preventDefault();

    const button = form.querySelector('button[type="submit"]');
    if (button instanceof HTMLButtonElement) button.disabled = true;

    // Anything unexpected — an error from Formspree, a network failure — falls
    // back to a normal POST. `form.submit()` bypasses this handler, so no loop.
    const fallback = () => {
      if (button instanceof HTMLButtonElement) button.disabled = false;
      form.submit();
    };

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });
      if (!response.ok) {
        fallback();
        return;
      }
      // Redirect same-origin, deriving the path from `_next` so there's one
      // source of truth for it (its value is absolute, for the no-JS fallback).
      const next = form.querySelector('input[name="_next"]');
      const path =
        next instanceof HTMLInputElement && next.value
          ? new URL(next.value).pathname
          : '/contact/thanks/';
      window.location.href = path;
    } catch {
      fallback();
    }
  });
</script>
