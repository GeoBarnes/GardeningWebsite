---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact">
  <section class="max-w-2xl mx-auto px-6 py-16">
    <h1 class="font-display text-3xl mb-2">Contact</h1>
    <p class="text-forest/70 mb-8">
      Get in touch about a project — or call/email directly if that's easier.
    </p>

    <!--
      Prototype form: not yet wired to a real endpoint.
      Phase 6 replaces the action below with a Formspree endpoint
      (https://formspree.io/f/your-form-id) once an account exists.
    -->
    <form class="space-y-4" method="POST" action="#">
      <div>
        <label for="name" class="block text-sm font-medium mb-1">Name</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          class="w-full border border-earth-light/60 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-forest-light"
        />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium mb-1">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="w-full border border-earth-light/60 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-forest-light"
        />
      </div>
      <div>
        <label for="message" class="block text-sm font-medium mb-1">Message</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="w-full border border-earth-light/60 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-forest-light"
        ></textarea>
      </div>

      <!-- Honeypot: hidden from real users via CSS, bots often fill it in -->
      <div class="absolute -left-[9999px]" aria-hidden="true">
        <label for="company">Company</label>
        <input type="text" id="company" name="company" tabindex="-1" autocomplete="off" />
      </div>

      <button
        type="submit"
        class="bg-forest text-white px-6 py-3 rounded-full font-medium hover:bg-forest-light transition-colors"
      >
        Send message
      </button>
    </form>

    <div class="mt-10 pt-8 border-t border-earth-light/40 text-forest/80 text-sm">
      <p>Prefer to call or email directly?</p>
      <p class="mt-1">Phone: <a href="tel:+447000000000" class="underline">07000 000000</a></p>
      <p>Email: <a href="mailto:hello@example.com" class="underline">hello@example.com</a></p>
    </div>
  </section>
</BaseLayout>
