---
// Thumbnail grid that opens into a PhotoSwipe lightbox.
//
// The markup is a plain list of links to the full-size images, so it still
// works with JS disabled — clicking a thumbnail just opens the image directly.
// PhotoSwipe enhances that into an overlay gallery.
import type { ProjectImage } from '../content/schema';

interface Props {
  images: ProjectImage[];
  /** Fallback alt text when an image has none of its own. */
  title: string;
}

const { images, title } = Astro.props;
---

<div class="grid sm:grid-cols-2 gap-4 mb-8" id="project-gallery">
  {
    images.map((image) => (
      <a
        href={image.src}
        data-pswp-width={image.width}
        data-pswp-height={image.height}
        class="block rounded-lg overflow-hidden focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-forest"
      >
        <img
          src={image.src}
          alt={image.alt ?? title}
          width={image.width}
          height={image.height}
          loading="lazy"
          class="w-full aspect-[3/2] object-cover"
        />
      </a>
    ))
  }
</div>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  // View transitions swap the document without reloading it, so a lightbox
  // bound on first load would be left pointing at a gallery that is no longer
  // in the page. Rebuild it per page, and tear the old one down.
  let lightbox: PhotoSwipeLightbox | null = null;

  const init = () => {
    // Guarded because this runs both directly and from `astro:page-load`, and
    // which of the two fires first depends on whether this module had already
    // been loaded by an earlier page.
    if (lightbox || !document.getElementById('project-gallery')) return;

    lightbox = new PhotoSwipeLightbox({
      gallery: '#project-gallery',
      children: 'a',
      // The core module is a dynamic import, so its weight lands only when a
      // visitor actually opens an image rather than on page load.
      pswpModule: () => import('photoswipe'),
    });

    // PhotoSwipe doesn't lock the document behind the overlay — it only stops
    // scroll on the layer it owns. Without this the page keeps scrolling behind
    // the fixed lightbox (very visible in Safari and on phones, where it reads
    // as the overlay "sticking" mid-page). Lock <html> while it's open and
    // compensate for the vanished scrollbar so nothing jumps on close.
    lightbox.on('beforeOpen', () => {
      const gutter = window.innerWidth - document.documentElement.clientWidth;
      document.documentElement.style.setProperty('--pswp-gutter', `${gutter}px`);
      document.documentElement.classList.add('pswp-open');
    });
    lightbox.on('close', () => {
      document.documentElement.classList.remove('pswp-open');
    });

    // No alt-text wiring needed: PhotoSwipe copies each thumbnail's `alt` onto
    // the full-size image itself, so the overlay is labelled for screen readers
    // as long as the thumbnails are.
    lightbox.init();

    // Once the lightbox is open PhotoSwipe deliberately ignores further clicks
    // on the thumbnails and lets the browser follow the link (see its
    // `onThumbnailsClick`: it returns early while `window.pswp` is set). So the
    // second click of a double-click navigated to the raw image. Swallow any
    // thumbnail click while the lightbox is open — PhotoSwipe owns the UI then.
    // The link stays live with JS disabled, which is the whole point of it.
    document.getElementById('project-gallery')?.addEventListener('click', (event) => {
      const openLightbox = (window as unknown as { pswp?: unknown }).pswp;
      if (openLightbox && (event.target as HTMLElement).closest('a')) {
        event.preventDefault();
      }
    });
  };

  init();
  document.addEventListener('astro:page-load', init);
  document.addEventListener('astro:before-swap', () => {
    lightbox?.destroy();
    lightbox = null;
  });
</script>
