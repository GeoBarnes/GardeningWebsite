---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { SITE_INDEXABLE } from '../config';

interface Props {
  title: string;
  description?: string;
  /** Keeps a page out of search results. For pages that only make sense as the
   * end of a journey — the form confirmation — not as an entry point. */
  noindex?: boolean;
}

const {
  title,
  description = 'Friendly, experienced garden design and maintenance.',
  noindex = false,
} = Astro.props;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/portfolio/', label: 'Portfolio' },
  { href: '/about/', label: 'About' },
  { href: '/contact/', label: 'Contact' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Placeholder Gardening Co.</title>
    <meta name="description" content={description} />
    {
      /* While the site is a prototype every page is held back, not just the
         ones marked noindex individually. `nofollow` too, so a crawler that
         reaches one page does not spider outward from it. */
      (!SITE_INDEXABLE || noindex) && (
        <meta name="robots" content={SITE_INDEXABLE ? 'noindex' : 'noindex, nofollow'} />
      )
    }
    <ClientRouter />
    <!--
      Marks JS as available before the first paint, which is what lets the
      scroll-reveal CSS hide elements without risking a blank page if the
      script never arrives. `is:inline` keeps it un-bundled and blocking —
      it must win the race against rendering, and it is one line.
    -->
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600&family=Inter:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen flex flex-col bg-white font-body text-forest">
    <header class="border-b border-earth-light/40">
      <nav class="max-w-5xl mx-auto px-6 py-4" aria-label="Main">
        <div class="flex items-center justify-between">
          <a href="/" class="font-display text-xl text-forest">Placeholder Gardening Co.</a>

          <!-- Desktop links: the whole list inline, from `sm` up. -->
          <ul class="hidden sm:flex gap-6 text-sm">
            {
              navLinks.map((link) => (
                <li>
                  <a href={link.href} class="hover:text-forest-light transition-colors">
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>

          <!--
            Mobile toggle. `aria-expanded` is the state contract screen readers
            read; `aria-controls` ties it to the panel. Both are kept in sync by
            the script below. 44px min touch target per WCAG 2.5.5.
          -->
          <button
            type="button"
            id="nav-toggle"
            class="sm:hidden -mr-2 p-2 min-w-11 min-h-11 flex items-center justify-center"
            aria-expanded="false"
            aria-controls="nav-menu"
            aria-label="Menu"
          >
            <svg
              class="w-6 h-6"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              aria-hidden="true"
            >
              <line x1="3" y1="6" x2="21" y2="6"></line>
              <line x1="3" y1="12" x2="21" y2="12"></line>
              <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
          </button>
        </div>

        <!--
          Mobile panel. Hidden via the `hidden` attribute rather than a class so
          it is genuinely removed from the accessibility tree when closed, not
          merely invisible.
        -->
        <ul id="nav-menu" hidden class="sm:hidden flex flex-col gap-1 pt-4 text-sm">
          {
            navLinks.map((link) => (
              <li>
                <a href={link.href} class="block py-3 hover:text-forest-light transition-colors">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-earth-light/40 mt-16">
      <div
        class="max-w-5xl mx-auto px-6 py-8 text-sm text-forest/80 flex flex-col sm:flex-row justify-between gap-2"
      >
        <p>&copy; {new Date().getFullYear()} Placeholder Gardening Co.</p>
        <p>Serving [service area] &middot; hello@example.com &middot; 07000 000000</p>
      </div>
    </footer>

    <script>
      // The site's only always-present JS. Everything else stays zero-JS
      // unless a page opts in.
      //
      // Every listener here is delegated to `document` and looks its elements
      // up at call time. That is not stylistic: view transitions replace the
      // <body> on each navigation, so a listener bound directly to the toggle
      // would be thrown away with the old DOM, and one bound once to a captured
      // element would go on pointing at a node no longer in the page. Delegation
      // means this binds once and keeps working, with nothing to re-initialise.

      const setOpen = (open: boolean) => {
        const toggle = document.getElementById('nav-toggle');
        const menu = document.getElementById('nav-menu');
        if (!toggle || !menu) return;

        menu.hidden = !open;
        toggle.setAttribute('aria-expanded', String(open));
      };

      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        if (!target.closest('#nav-toggle')) return;

        // `hidden` types as `boolean | string` (the `until-found` value), so
        // coerce rather than pass it straight through.
        setOpen(Boolean(document.getElementById('nav-menu')?.hidden));
      });

      // Escape closes and returns focus to the toggle — otherwise keyboard
      // users are stranded inside an open panel.
      document.addEventListener('keydown', (event) => {
        if (event.key !== 'Escape') return;
        const menu = document.getElementById('nav-menu');
        if (!menu || menu.hidden) return;

        setOpen(false);
        document.getElementById('nav-toggle')?.focus();
      });

      // Crossing the `sm` breakpoint with the panel open would otherwise
      // leave a stale `hidden` state behind when the desktop list takes over.
      window.matchMedia('(min-width: 40rem)').addEventListener('change', (event) => {
        if (event.matches) setOpen(false);
      });

      // ---- Scroll reveal ----------------------------------------------------
      // The CSS does the animating; this only decides when. Elements start
      // hidden solely via the `.js` gate, so if this script fails they stay
      // visible rather than disappearing.

      let observer: IntersectionObserver | null = null;

      const revealAll = (targets: NodeListOf<Element>) => {
        targets.forEach((el) => el.setAttribute('data-revealed', ''));
      };

      const initReveal = () => {
        const targets = document.querySelectorAll('[data-reveal]:not([data-revealed])');
        if (targets.length === 0) return;

        // Checked here rather than only in CSS so we skip the observer work
        // entirely, and so anything below the fold is shown immediately.
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          revealAll(targets);
          return;
        }

        observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;
              entry.target.setAttribute('data-revealed', '');
              // One-shot: re-animating on every scroll past is a nuisance, not
              // a delight.
              observer?.unobserve(entry.target);
            }
          },
          // Fire a little before the element is fully in view, so the movement
          // reads as the page settling rather than as a delayed reaction.
          { rootMargin: '0px 0px -10% 0px' }
        );

        targets.forEach((el) => observer?.observe(el));
      };

      // Runs on first load; `astro:page-load` covers every view transition after
      // it, where the new page arrives with its own un-revealed elements.
      initReveal();
      document.addEventListener('astro:page-load', initReveal);
      document.addEventListener('astro:before-swap', () => {
        observer?.disconnect();
        observer = null;
      });
    </script>
  </body>
</html>
