---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Friendly, experienced garden design and maintenance.' } = Astro.props;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Placeholder Gardening Co.</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600&family=Inter:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen flex flex-col bg-white font-body text-forest">
    <header class="border-b border-earth-light/40">
      <nav class="max-w-5xl mx-auto flex items-center justify-between px-6 py-4">
        <a href="/" class="font-display text-xl text-forest">Placeholder Gardening Co.</a>
        <ul class="flex gap-6 text-sm">
          {
            navLinks.map((link) => (
              <li>
                <a href={link.href} class="hover:text-forest-light transition-colors">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-earth-light/40 mt-16">
      <div
        class="max-w-5xl mx-auto px-6 py-8 text-sm text-forest/80 flex flex-col sm:flex-row justify-between gap-2"
      >
        <p>&copy; {new Date().getFullYear()} Placeholder Gardening Co.</p>
        <p>Serving [service area] &middot; hello@example.com &middot; 07000 000000</p>
      </div>
    </footer>
  </body>
</html>
